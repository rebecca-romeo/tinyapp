<header>
  <nav class="navbar navbar-expand-md navbar-dark bg-success">
    <a class="navbar-brand" href="/urls">TinyApp</a>
    <button
      class="navbar-toggler"
      type="button"
      data-toggle="collapse"
      data-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-item nav-link" href="/urls">My URLs</a>
        <a class="nav-item nav-link" href="/urls/new">Create New URL</a>
      </div>
    </div>

    <!-- if user logged in ? display username and logout button : display login form and signin button -->
    <% if(user){ %>
      <!-- Display the username -->
      <div>
        <p style="padding-right: 15px">Signed in as: <%= user["email"] %></p>
      </div>

      <!-- Logout button -->
      <form action="/logout" method="POST" >

        <div style="display: flex; justify-content: center; align-items: center;">
          <label for="username"> </label>
          <button type="submit" class="btn btn-primary"> Logout</button>
        </div>
      </form>

    <% } else{ %>

      <a href="/login" class="btn btn-primary" style="margin-right: 10px">Login</a>
      <a href="/register" class="btn btn-primary";">Register</a>

    <% } %>
  </nav>
</header>